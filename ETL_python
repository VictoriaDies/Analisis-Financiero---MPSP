## 3. Calendar table

# Calendar script 

# Modulo 
import pandas as pd
import locale
locale.setlocale(locale.LC_TIME, 'Spanish_Spain.1252')


# Start y End date
start_date = pd.Timestamp('2010-01-01')
end_date = pd.Timestamp.today().normalize()  # Solo fecha, sin hora

# date list
df_calendar = pd.DataFrame({'Date': pd.date_range(start=start_date, end=end_date, freq='D')})

# IdDate (YYYYMMDD as a number)
df_calendar['IdDate'] = df_calendar['Date'].dt.strftime('%Y%m%d').astype(int)

# Year
df_calendar['Year'] = df_calendar['Date'].dt.year

# Quarter (Q1, Q2, Q3, Q4)
df_calendar['Quarter'] = 'Q' + df_calendar['Date'].dt.quarter.astype(str)

# IdMonth
df_calendar['IdMonth'] = df_calendar['Date'].dt.month

# Month in spanish
df_calendar['Month'] = df_calendar['Date'].dt.strftime('%B')  # Modulo 

# Period (YYYYMM)
df_calendar['Period'] = df_calendar['Year'].astype(str) + df_calendar['IdMonth'].astype(str).str.zfill(2)

# QuarterYear (QYYYY)
df_calendar['QuarterYear'] = df_calendar['Year'].astype(str) + df_calendar['Quarter']

# Day
df_calendar['Day'] = df_calendar['Date'].dt.day

# Day Name
df_calendar['Day_Name'] = df_calendar['Date'].dt.strftime('%A')  # Modulo

print(df_calendar)
